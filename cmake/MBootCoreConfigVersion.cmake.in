set(PACKAGE_VERSION "@PROJECT_VERSION@")

if(PACKAGE_FIND_VERSION_MAJOR STREQUAL "1")
  if(PACKAGE_FIND_VERSION_MINOR STREQUAL "0")
    if(PACKAGE_FIND_VERSION_PATCH STREQUAL "0")
      set(PACKAGE_VERSION_EXACT ON)
    endif()
    set(PACKAGE_VERSION_COMPATIBLE ON)
  elseif(PACKAGE_FIND_VERSION_MINOR LESS "1")
    set(PACKAGE_VERSION_COMPATIBLE ON)
  else()
    set(PACKAGE_VERSION_COMPATIBLE OFF)
  endif()
else()
  set(PACKAGE_VERSION_COMPATIBLE OFF)
endif()

if(PACKAGE_FIND_VERSION STREQUAL PACKAGE_VERSION)
  set(PACKAGE_VERSION_EXACT ON)
endif()
