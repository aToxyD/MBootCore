# MBootCore Build Metadata — generated at configure time.
# Consumed by release/SDKDistribution.cmake via cmake -P.
set(MBOOTCORE_PLATFORM_NAME    "@MBOOTCORE_PLATFORM_NAME@")
set(MBOOTCORE_ARCH             "@MBOOTCORE_ARCH@")
set(MBOOTCORE_VERSION          "@MBOOTCORE_VERSION@")
set(MBOOTCORE_COMPILER         "@CMAKE_CXX_COMPILER_ID@")
set(MBOOTCORE_COMPILER_VERSION "@CMAKE_CXX_COMPILER_VERSION@")
set(MBOOTCORE_CXX_STANDARD     "@CMAKE_CXX_STANDARD@")
set(MBOOTCORE_GENERATOR        "@CMAKE_GENERATOR@")
set(MBOOTCORE_CMAKE_VERSION    "@CMAKE_VERSION@")
set(MBOOTCORE_BUILD_TYPE       "@CMAKE_BUILD_TYPE@")
set(MBOOTCORE_DOCDIR           "@CMAKE_INSTALL_DOCDIR@")
