#include <mbootcore/plugin/IPlugin.hpp>
#include <mbootcore/plugin/PluginContext.hpp>
#include <mbootcore/plugin/PluginABI.hpp>
#include <mbootcore/domain/Error.hpp>

#include <string>
#include <vector>
#include <cstdint>
#include <atomic>

using namespace mbootcore;
using namespace mbootcore::plugin;
namespace disc = mbootcore::discovery;

class %VENDOR_NAME%Plugin final : public IPlugin {
public:
    %VENDOR_NAME%Plugin() = default;
    ~%VENDOR_NAME%Plugin() override = default;

    PluginMetadata metadata() const noexcept override {
        PluginMetadata meta;
        meta.name = "%VENDOR_NAME%";
        meta.version = "1.0.0";
        meta.apiVersion = PluginABIVersion;
        meta.vendor = disc::Vendor::%VENDOR_ENUM%;
        meta.author = "%AUTHOR%";
        meta.license = "%LICENSE%";
        meta.description = "%VENDOR_DESCRIPTION%";
        meta.capabilities = PluginCapability::Vendor;
        meta.priority = 100;
        meta.uuid = "%UUID%";
        meta.compatibilityVersion = 1;
        return meta;
    }

    PluginState state() const noexcept override {
        return state_;
    }

    void setEnabled(bool enabled) noexcept override {
        enabled_ = enabled;
    }

    bool isEnabled() const noexcept override {
        return enabled_;
    }

    Result<void> initialize(PluginContext& context) override {
        context.log("%VENDOR_NAME% vendor plugin initializing...");
        state_ = PluginState::Initialized;
        return Result<void>::Ok();
    }

    Result<void> shutdown() noexcept override {
        state_ = PluginState::Loaded;
        return Result<void>::Ok();
    }

    Result<void> registerComponents(PluginContext& context) override {
        auto* mgr = context.deviceManager();
        if (mgr) {
            context.log("Registering %VENDOR_NAME% vendor with DeviceManager");
        }
        state_ = PluginState::Initialized;
        return Result<void>::Ok();
    }

    Result<void> unregisterComponents(PluginContext& context) override {
        context.log("Unregistering %VENDOR_NAME% vendor plugin");
        state_ = PluginState::Loaded;
        return Result<void>::Ok();
    }

    disc::Vendor vendor() const noexcept override {
        return disc::Vendor::%VENDOR_ENUM%;
    }

    std::vector<VidPidEntry> vidPidTable() const override {
        return {
            { 0x%VID%, 0x%PID%, "%DEVICE_DESCRIPTION%" }
        };
    }

    std::vector<ChipsetInfo> knownChipsets() const override {
        return {
            { "%CHIPSET_NAME%", { %CHIPSET_IDS% } }
        };
    }

    std::vector<disc::BootMode> bootModes() const noexcept override {
        return {
            disc::BootMode::%BOOT_MODE%
        };
    }

private:
    PluginState state_{PluginState::Unloaded};
    bool enabled_{true};
};

extern "C" {
MBOOTCORE_PLUGIN_EXPORT IPlugin* mbootcore_plugin_create() {
    return new %VENDOR_NAME%Plugin();
}

MBOOTCORE_PLUGIN_EXPORT void mbootcore_plugin_destroy(IPlugin* plugin) {
    delete plugin;
}

MBOOTCORE_PLUGIN_EXPORT uint32_t mbootcore_plugin_abi_version() {
    return PluginABIVersion;
}
}
