cmake_minimum_required(VERSION 3.20)
project(%PLUGIN_NAME% VERSION 1.0.0 LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

find_package(mbootcore REQUIRED)

add_library(%PLUGIN_NAME% MODULE src/main.cpp)
target_link_libraries(%PLUGIN_NAME% PRIVATE mbootcore::mbootcore)
target_include_directories(%PLUGIN_NAME% PRIVATE ${mbootcore_INCLUDE_DIRS})
target_compile_features(%PLUGIN_NAME% PRIVATE cxx_std_17)

if(WIN32)
    set_target_properties(%PLUGIN_NAME% PROPERTIES
        LIBRARY_OUTPUT_DIRECTORY "${CMAKE_BINARY_DIR}/plugins"
        PREFIX ""
        SUFFIX ".dll"
    )
elseif(APPLE)
    set_target_properties(%PLUGIN_NAME% PROPERTIES
        LIBRARY_OUTPUT_DIRECTORY "${CMAKE_BINARY_DIR}/plugins"
        PREFIX ""
        SUFFIX ".dylib"
    )
else()
    set_target_properties(%PLUGIN_NAME% PROPERTIES
        LIBRARY_OUTPUT_DIRECTORY "${CMAKE_BINARY_DIR}/plugins"
        PREFIX ""
    )
endif()

install(TARGETS %PLUGIN_NAME%
    LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}/mbootcore/plugins
    RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR}/plugins
)
